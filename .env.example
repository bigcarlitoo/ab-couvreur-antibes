# --- AB Couvreur Antibes V2 — environment variables ---

# Public site URL (used for canonical, sitemap, robots, Open Graph, schema)
# À remplacer par le vrai domaine du client une fois choisi.
NEXT_PUBLIC_SITE_URL=

# Payload CMS
PAYLOAD_SECRET="change-me-in-production"
DATABASE_URI="file:./payload.db"

# --- Email notifications for lead submissions (production) ---
# Transactional email via Resend (https://resend.com).
#   1. Créer un compte Resend, vérifier le domaine d'envoi du client.
#   2. Générer une API key et la coller ci-dessous.
# Sans ces 3 variables, les leads sont seulement loggés côté serveur (jamais perdus
# mais aucun email n'est envoyé). À configurer impérativement avant la mise en prod.
RESEND_API_KEY=

# Adresse qui reçoit les notifications de devis (boîte mail du couvreur).
# À renseigner dès que le client communique son adresse de contact.
LEAD_NOTIFICATION_EMAIL=

# Adresse expéditrice (FROM) — doit être sur un domaine vérifié dans Resend.
# Ex.: "AB Couvreur <devis@domaine-verifie.fr>"
LEAD_FROM_EMAIL=

# --- Heatmaps & enregistrements de session (Microsoft Clarity) ---
# Gratuit, illimité. Créer un projet sur https://clarity.microsoft.com/
# puis coller l'ID du projet (visible dans Settings → Overview).
# Activé uniquement après consentement utilisateur (bandeau cookies).
# Si vide, aucun script Clarity n'est chargé.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
